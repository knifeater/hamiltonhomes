.success-reset{margin-top:8px;background:transparent;border:1px solid var(--border-b);border-radius:3px;padding:12px 28px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;color:var(--blue);letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;transition:background 0.25s,border-color 0.25s;animation:successIn 0.4s 0.55s both;}
