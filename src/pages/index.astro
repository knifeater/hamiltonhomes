.cs-dropdown{position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:50;background:var(--navy-mid);border:1px solid var(--border-b);border-radius:4px;overflow:hidden;max-height:0;opacity:0;transition:max-height 0.38s cubic-bezier(0.4,0,0.2,1),opacity 0.25s ease;box-shadow:0 16px 48px rgba(0,0,0,0.4);}
