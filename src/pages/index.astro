---
import { properties } from "../data/properties.js";

const soldListings    = properties.filter((p) => p.status === "sold");
const currentListings = properties.filter(
  (p) => p.status === "for-sale" || p.status === "under-offer"
);

const featuredSold    = soldListings.slice(0, 3);
const featuredCurrent = currentListings.slice(0, 3);
---

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sopo Fuifui | Real Estate | Hamilton Homes</title>
<link rel="icon" type="image/png" href="/images/HamiltonHomes_favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
:root {
  --navy:       #162040;
  --navy-mid:   #1E2D56;
  --navy-light: #253570;
  --blue:       #00AEEF;
  --blue-mid:   #0090CC;
  --blue-pale:  #E0F5FD;
  --blue-ghost: rgba(0,174,239,0.08);
  --white:      #FFFFFF;
  --off-white:  #F5F8FC;
  --text:       #1A2744;
  --muted:      #7A8499;
  --border-b:   rgba(0,174,239,0.25);
  --border-w:   rgba(255,255,255,0.1);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;width:100%;overflow-x:hidden;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--off-white);color:var(--text);overflow-x:hidden;width:100%;margin:0;padding:0;}

/* ========================= NAV ========================= */
nav{position:fixed;top:0;left:0;right:0;z-index:300;height:76px;display:flex;align-items:center;justify-content:space-between;padding:0 56px;background:var(--navy);border-bottom:2px solid var(--blue);}
.nav-left{display:flex;align-items:center;gap:20px;transition:opacity 0.25s;}
.nav-left:hover{opacity:0.82;}
.nav-left:hover .nav-brand-name{color:var(--blue);}
.nav-left img{transition:opacity 0.25s;}
.hc-mark{display:flex;flex-direction:column;gap:3px;}
.hc-word{font-size:20px;font-weight:700;color:var(--white);letter-spacing:-0.01em;line-height:1;}
.hc-bar{width:26px;height:3px;background:var(--blue);border-radius:1px;}
.nav-sep{width:1px;height:42px;background:rgba(255,255,255,0.18);}
.nav-agent-name{font-size:14px;font-weight:600;color:var(--white);}
.nav-agent-role{font-size:10px;font-weight:300;color:var(--blue);letter-spacing:0.18em;text-transform:uppercase;}
.nav-brand-name{font-size:18px;font-weight:700;color:var(--white);letter-spacing:0.01em;line-height:1.1;transition:color 0.25s;}
.nav-brand-sub{font-size:10px;font-weight:400;color:var(--blue);letter-spacing:0.32em;text-transform:uppercase;margin-top:3px;opacity:0.85;}
.nav-links{display:flex;align-items:center;gap:36px;list-style:none;}
.nav-links a{font-size:12px;font-weight:400;color:rgba(255,255,255,0.65);text-decoration:none;letter-spacing:0.08em;text-transform:uppercase;transition:color 0.25s;}
.nav-links a:hover{color:var(--blue);}
.nav-cta{background:var(--blue)!important;color:var(--navy)!important;padding:10px 24px!important;border-radius:3px;font-weight:600!important;transition:background 0.25s!important;text-decoration:none!important;border-bottom:none!important;}
.nav-cta:hover{background:#33BFFF!important;}
.hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;width:40px;height:40px;cursor:pointer;background:none;border:none;padding:6px;border-radius:3px;transition:background 0.2s;flex-shrink:0;}
.hamburger:hover{background:rgba(255,255,255,0.07);}
.hamburger span{display:block;height:2px;background:var(--white);border-radius:2px;transition:transform 0.38s cubic-bezier(0.4,0,0.2,1),opacity 0.25s ease,width 0.3s ease;transform-origin:center;}
.hamburger span:nth-child(1){width:22px;}
.hamburger span:nth-child(2){width:16px;}
.hamburger span:nth-child(3){width:22px;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);width:22px;}
.hamburger.open span:nth-child(2){opacity:0;width:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);width:22px;}
.mobile-menu{position:fixed;top:76px;left:0;right:0;bottom:0;z-index:290;background:var(--navy);display:flex;flex-direction:column;transform:translateX(100%);transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);overflow-y:auto;padding:40px 32px 60px;border-top:1px solid rgba(0,174,239,0.2);}
.mobile-menu.open{transform:translateX(0);}
.mobile-menu ul{list-style:none;display:flex;flex-direction:column;gap:4px;margin-bottom:40px;}
.mobile-menu ul li{opacity:0;transform:translateX(24px);transition:opacity 0.35s ease,transform 0.35s ease;}
.mobile-menu.open ul li{opacity:1;transform:translateX(0);}
.mobile-menu.open ul li:nth-child(1){transition-delay:0.08s;}
.mobile-menu.open ul li:nth-child(2){transition-delay:0.13s;}
.mobile-menu.open ul li:nth-child(3){transition-delay:0.18s;}
.mobile-menu.open ul li:nth-child(4){transition-delay:0.23s;}
.mobile-menu ul li a{display:block;font-size:26px;font-family:'Cormorant Garamond',serif;font-weight:300;color:rgba(255,255,255,0.75);text-decoration:none;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.06);transition:color 0.2s;letter-spacing:0.02em;}
.mobile-menu ul li a:hover{color:var(--blue);}
.mobile-menu-cta{background:var(--blue);color:var(--navy);border:none;padding:16px 32px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:3px;width:100%;opacity:0;transform:translateY(12px);transition:opacity 0.35s ease 0.3s,transform 0.35s ease 0.3s,background 0.25s;text-decoration:none;}
.mobile-menu.open .mobile-menu-cta{opacity:1;transform:translateY(0);}
.mobile-menu-cta:hover{background:#33BFFF;}
.mobile-contact-row{display:flex;gap:12px;margin-top:16px;opacity:0;transform:translateY(12px);transition:opacity 0.35s ease 0.36s,transform 0.35s ease 0.36s;}
.mobile-menu.open .mobile-contact-row{opacity:1;transform:translateY(0);}
.mobile-contact-link{flex:1;display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.6);font-size:12px;font-weight:400;letter-spacing:0.06em;text-transform:uppercase;text-decoration:none;padding:13px 16px;border-radius:3px;transition:border-color 0.2s,color 0.2s;}
.mobile-contact-link:hover{border-color:var(--blue);color:var(--blue);}

/* ========================= HERO ========================= */
.hero{position:relative;height:100vh;min-height:640px;display:flex;align-items:center;overflow:hidden;background:var(--navy);}
.hero-split{position:absolute;top:0;right:0;width:60%;height:100%;background:var(--navy-mid);clip-path:polygon(10% 0,100% 0,100% 100%,0% 100%);}
.hero-grid{position:absolute;top:0;right:0;width:60%;height:100%;clip-path:polygon(10% 0,100% 0,100% 100%,0% 100%);opacity:0.06;background-image:repeating-linear-gradient(0deg,var(--blue) 0,var(--blue) 1px,transparent 1px,transparent 60px),repeating-linear-gradient(90deg,var(--blue) 0,var(--blue) 1px,transparent 1px,transparent 60px);}
.hero-glow{position:absolute;top:15%;right:8%;width:380px;height:380px;border-radius:50%;background:radial-gradient(circle,rgba(0,174,239,0.2) 0%,transparent 70%);pointer-events:none;}
.hero-accent{position:absolute;top:0;left:40%;width:2px;height:100%;background:linear-gradient(to bottom,transparent,var(--blue),transparent);opacity:0.3;}
.hero-illo{position:absolute;top:0;right:0;width:60%;height:100%;opacity:0.7;object-fit:cover;object-position:70% center;clip-path:polygon(10% 0,100% 0,100% 100%,0% 100%);}
.hero-content{position:relative;z-index:2;padding:76px 80px 0;max-width:1400px;width:100%;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:60px;}
.hero-tag{display:inline-flex;align-items:center;gap:10px;background:rgba(0,174,239,0.1);border:1px solid var(--border-b);border-radius:2px;padding:7px 16px;margin-bottom:28px;animation:fadeUp 0.7s 0.1s both;}
.hero-tag-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);}
.hero-tag-txt{font-size:11px;font-weight:400;color:var(--blue);letter-spacing:0.2em;text-transform:uppercase;}
.hero-name{font-family:'Cormorant Garamond',serif;font-size:clamp(48px,6.5vw,88px);font-weight:400;color:var(--white);line-height:0.95;letter-spacing:-0.02em;margin-bottom:24px;animation:fadeUp 0.8s 0.25s both;}
.hero-name .first{display:block;}
.hero-name .last{display:block;color:var(--blue);font-style:italic;}
.hero-tagline{font-size:15px;font-weight:400;color:rgba(255,255,255,0.72);line-height:1.8;max-width:440px;margin-bottom:44px;animation:fadeUp 0.8s 0.4s both;}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;animation:fadeUp 0.8s 0.5s both;}
.btn-blue{background:var(--blue);color:var(--navy);border:none;padding:15px 34px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:3px;transition:all 0.3s;text-decoration:none;display:inline-block;}
.btn-blue:hover{background:#33BFFF;transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,174,239,0.35);}
.btn-ghost-w{background:transparent;color:var(--white);border:1px solid rgba(255,255,255,0.28);padding:14px 34px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:3px;transition:all 0.3s;text-decoration:none;display:inline-block;}
.btn-ghost-w:hover{border-color:var(--blue);color:var(--blue);}
.hero-card{background:rgba(255,255,255,0.04);backdrop-filter:blur(16px);border:1px solid var(--border-b);border-radius:6px;padding:36px;animation:fadeUp 0.8s 0.3s both;}
.hero-card-title{font-size:10px;font-weight:500;color:var(--blue);letter-spacing:0.25em;text-transform:uppercase;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,0.07);}
.hero-stats{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-bottom:24px;}
.h-stat-num{font-family:'Cormorant Garamond',serif;font-size:42px;font-weight:400;color:var(--white);line-height:1;margin-bottom:4px;}
.h-stat-num span{color:var(--blue);}
.h-stat-lbl{font-size:11px;font-weight:300;color:rgba(255,255,255,0.38);letter-spacing:0.1em;}
.hero-card-bot{background:var(--blue-ghost);border:1px solid var(--border-b);border-radius:3px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;transition:background 0.25s;}
.hero-card-bot:hover{background:rgba(0,174,239,0.14);}
.hcb-txt{font-size:12px;font-weight:300;color:rgba(255,255,255,0.55);}
.hcb-arrow{color:var(--blue);font-size:16px;}
.scroll-hint{position:absolute;bottom:36px;left:80px;display:flex;align-items:center;gap:12px;color:rgba(255,255,255,0.22);font-size:10px;letter-spacing:0.2em;text-transform:uppercase;animation:fadeUp 1s 0.8s both;}
.scroll-line{width:36px;height:1px;background:linear-gradient(to right,var(--blue),transparent);}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}

/* ========================= TRUST BAR ========================= */
.trust-bar{background:var(--white);padding:20px 80px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(22,32,64,0.08);box-shadow:0 2px 18px rgba(22,32,64,0.06);flex-wrap:wrap;gap:16px;}
.trust-items{display:flex;align-items:center;gap:32px;flex-wrap:wrap;}
.trust-item{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:400;color:var(--muted);}
.t-icon{width:18px;height:18px;color:var(--blue);flex-shrink:0;}
.trust-sep{width:1px;height:22px;background:rgba(22,32,64,0.08);}
.trust-hc{display:flex;align-items:center;gap:10px;}
.thc-logo{font-size:16px;font-weight:700;color:var(--navy);}
.thc-sub{display:flex;flex-direction:column;gap:2px;}
.thc-line{width:20px;height:2.5px;background:var(--blue);border-radius:1px;}
.thc-label{font-size:10px;font-weight:300;color:var(--muted);letter-spacing:0.1em;}

/* ========================= SHARED SECTION ========================= */
.section{padding:96px 80px;max-width:1400px;margin:0 auto;}
.sec-eyebrow{display:flex;align-items:center;gap:11px;font-size:11px;font-weight:500;color:var(--blue);letter-spacing:0.25em;text-transform:uppercase;margin-bottom:11px;}
.sec-line{width:26px;height:2px;background:var(--blue);border-radius:1px;}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:clamp(34px,4vw,52px);font-weight:400;color:var(--navy);line-height:1.05;}
.sec-title em{font-style:italic;color:var(--blue-mid);}
.sec-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:52px;}
.view-all{font-size:12px;font-weight:500;color:var(--navy);text-decoration:none;letter-spacing:0.1em;text-transform:uppercase;display:flex;align-items:center;gap:6px;padding-bottom:2px;border-bottom:2px solid var(--blue);transition:color 0.2s;}
.view-all:hover{color:var(--blue);}

/* Sold section — white background to visually separate from off-white */
.sold-wrap{background:var(--white);}

/* ========================= LISTINGS / CARDS ========================= */
.listings-grid{display:grid;grid-template-columns:1.55fr 1fr;gap:20px;}
.col-right{display:flex;flex-direction:column;gap:20px;}
.pcard{position:relative;border-radius:6px;overflow:hidden;cursor:pointer;background:var(--navy);transition:transform 0.35s cubic-bezier(0.4,0,0.2,1),box-shadow 0.35s;text-decoration:none;display:block;}
.pcard:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(22,32,64,0.22);}
.pcard:hover .pimg-inner{transform:scale(1.04);}
.pimg{overflow:hidden;}
.pcard.lg .pimg{height:560px;}
.pcard.sm .pimg{height:258px;}
.pimg-inner{width:100%;height:100%;transition:transform 0.55s ease;display:flex;align-items:flex-end;justify-content:center;}
.pb1{background:linear-gradient(160deg,#2A3F7A 0%,#162040 50%,#0D1830 100%);}
.pb2{background:linear-gradient(160deg,#1E4060 0%,#122840 50%,#0A1C2C 100%);}
.pb3{background:linear-gradient(160deg,#2A4060 0%,#162040 60%,#101828 100%);}
.c-house{opacity:0.18;}
.poverlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(22,32,64,0.96) 0%,rgba(22,32,64,0.25) 50%,transparent 100%);}
.pbody{position:absolute;bottom:0;left:0;right:0;padding:24px;}
.pbadge{display:inline-block;padding:4px 12px;border-radius:2px;font-size:9px;font-weight:600;letter-spacing:0.25em;text-transform:uppercase;margin-bottom:10px;}
.b-sale{background:var(--blue);color:var(--navy);}
.b-offer{background:rgba(255,174,0,0.25);color:rgba(255,210,100,0.95);}
.b-sold{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);}
.paddress{font-family:'Cormorant Garamond',serif;color:var(--white);line-height:1.2;margin-bottom:3px;}
.pcard.lg .paddress{font-size:28px;font-weight:400;}
.pcard.sm .paddress{font-size:20px;font-weight:400;}
.psuburb{font-size:12px;font-weight:300;color:rgba(255,255,255,0.44);letter-spacing:0.08em;margin-bottom:13px;}
.pfooter{display:flex;align-items:center;justify-content:space-between;padding-top:11px;border-top:1px solid rgba(255,255,255,0.1);}
.pspecs{display:flex;gap:13px;}
.pspec{display:flex;align-items:center;gap:5px;font-size:12px;font-weight:300;color:rgba(255,255,255,0.52);}
.pprice{font-family:'Cormorant Garamond',serif;color:var(--blue);font-weight:400;}
.pcard.lg .pprice{font-size:26px;}
.pcard.sm .pprice{font-size:21px;}
.badge360{position:absolute;top:16px;right:16px;background:rgba(22,32,64,0.8);backdrop-filter:blur(8px);border:1px solid var(--border-b);border-radius:20px;padding:6px 14px;display:flex;align-items:center;gap:7px;transition:background 0.25s;cursor:pointer;}
.badge360:hover{background:var(--blue);}
.badge360 svg{color:var(--blue);transition:color 0.25s;}
.badge360:hover svg{color:var(--navy);}
.badge360 span{font-size:10px;font-weight:600;color:var(--blue);letter-spacing:0.15em;transition:color 0.25s;}
.badge360:hover span{color:var(--navy);}
.open-home-tag{position:absolute;top:16px;left:16px;background:var(--blue);color:var(--navy);font-size:9px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;padding:5px 12px;border-radius:2px;}

/* Empty state */
.no-listings{grid-column:1/-1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 40px;border:1px dashed rgba(0,174,239,0.2);border-radius:6px;background:rgba(0,174,239,0.02);}
.no-listings-icon{color:var(--blue);opacity:0.35;margin-bottom:20px;}
.no-listings-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:var(--navy);margin-bottom:8px;}
.no-listings-text{font-size:13px;font-weight:300;color:var(--muted);line-height:1.7;max-width:360px;}

/* ========================= DETAIL PREVIEW ========================= */
.detail-wrap{background:var(--navy);padding:100px 0 80px;}
.detail-inner{max-width:1400px;margin:0 auto;padding:0 80px;}
.detail-intro{text-align:center;margin-bottom:60px;}
.detail-intro .sec-eyebrow{justify-content:center;}
.detail-intro .sec-title{color:var(--white);}
.detail-intro .sec-title em{color:var(--blue);}
.dcard{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:8px;overflow:hidden;}
.dtopbar{background:rgba(0,174,239,0.06);border-bottom:1px solid rgba(0,174,239,0.13);padding:18px 32px;display:flex;align-items:center;justify-content:space-between;}
.dcrumb{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:300;color:rgba(255,255,255,0.32);letter-spacing:0.04em;}
.dcrumb-sep{color:var(--blue);opacity:0.45;}
.dcrumb-cur{color:rgba(255,255,255,0.65);}
.dstatus{display:flex;align-items:center;gap:8px;}
.dstatus-dot{width:7px;height:7px;border-radius:50%;background:var(--blue);animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.dstatus-txt{font-size:11px;font-weight:500;color:var(--blue);letter-spacing:0.15em;text-transform:uppercase;}
.dheader{padding:32px;display:grid;grid-template-columns:1fr auto;gap:32px;align-items:start;border-bottom:1px solid rgba(255,255,255,0.07);}
.dheader-row{display:flex;align-items:center;justify-content:space-between;width:100%;gap:32px;}
.d-eyebrow{font-size:11px;font-weight:400;color:var(--blue);letter-spacing:0.2em;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.d-eyebrow::before{content:'';width:18px;height:2px;background:var(--blue);border-radius:1px;display:block;}
.d-addr{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:400;color:var(--white);line-height:1;margin-bottom:6px;}
.d-sub{font-size:13px;font-weight:300;color:rgba(255,255,255,0.38);letter-spacing:0.06em;}
.d-price-col{text-align:right;}
.d-price-label{font-size:10px;font-weight:400;color:rgba(255,255,255,0.28);letter-spacing:0.2em;text-transform:uppercase;margin-bottom:6px;}
.d-price-num{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:400;color:var(--blue);line-height:1;margin-bottom:14px;}
.btn-enq{background:var(--blue);color:var(--navy);border:none;padding:13px 26px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-radius:3px;width:100%;transition:background 0.25s;text-decoration:none;display:block;text-align:center;}
.btn-enq:hover{background:#33BFFF;}
.btn-enq-sm{background:transparent;color:var(--blue);border:1px solid var(--border-b);padding:6px 16px;font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;border-radius:3px;transition:background 0.2s,border-color 0.2s;white-space:nowrap;}
.btn-enq-sm:hover{background:rgba(0,174,239,0.1);}
.btn-view-listing{display:block;margin-top:10px;text-align:center;padding:11px 26px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue);border:1px solid var(--border-b);border-radius:3px;text-decoration:none;transition:background 0.25s,color 0.25s;}
.btn-view-listing:hover{background:rgba(0,174,239,0.1);}
.dgallery{display:grid;grid-template-columns:1.8fr 1fr;grid-template-rows:280px 190px;gap:6px;padding:6px;}
.gcell{border-radius:4px;overflow:hidden;position:relative;}
.gcell.main{grid-row:1/3;}
.gph{width:100%;height:100%;transition:transform 0.4s ease;object-fit:cover;display:block;}
.gcell:hover .gph{transform:scale(1.04);}
