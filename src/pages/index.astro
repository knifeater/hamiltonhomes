<script is:inline>
(function () {
  var hamburger  = document.getElementById('hamburger');
  var mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', function () {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
    document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
  });
  document.querySelectorAll('.mobile-link').forEach(function (link) {
    link.addEventListener('click', function () {
      hamburger.classList.remove('open');
      mobileMenu.classList.remove('open');
      document.body.style.overflow = '';
    });
  });
  window.toggleSelect = function (id) {
    var trigger  = document.getElementById('trigger-'  + id);
    var dropdown = document.getElementById('dropdown-' + id);
    var isOpen   = dropdown.classList.contains('open');
    document.querySelectorAll('.cs-dropdown').forEach(function (d) { d.classList.remove('open'); });
    document.querySelectorAll('.cs-trigger').forEach(function  (t) { t.classList.remove('open'); });
    if (!isOpen) { dropdown.classList.add('open'); trigger.classList.add('open'); }
  };
  window.selectOption = function (id, value) {
    var trigger  = document.getElementById('trigger-'  + id);
    var dropdown = document.getElementById('dropdown-' + id);
    trigger.querySelector('.cs-value').textContent = value;
    trigger.classList.add('selected');
    trigger.classList.remove('open');
    dropdown.classList.remove('open');
    dropdown.querySelectorAll('.cs-option').forEach(function (o) {
      o.classList.toggle('picked', o.textContent.trim() === value);
    });
    // sync value into hidden input so Netlify receives it
    var hidden = document.getElementById('input-' + id);
    if (hidden) hidden.value = value;
  };
  document.addEventListener('click', function (e) {
    if (!e.target.closest('.custom-select')) {
      document.querySelectorAll('.cs-dropdown').forEach(function (d) { d.classList.remove('open'); });
      document.querySelectorAll('.cs-trigger').forEach(function  (t) { t.classList.remove('open'); });
    }
  });
  window.submitForm = function (e) {
    e.preventDefault();
    var form        = document.getElementById('enquiryForm');
    var formContent = document.getElementById('formContent');
    var formSuccess = document.getElementById('formSuccess');
    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(form)).toString()
    })
    .then(function () {
      formContent.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      formContent.style.opacity    = '0';
      formContent.style.transform  = 'translateY(-12px)';
      setTimeout(function () { formContent.style.display = 'none'; formSuccess.classList.add('show'); }, 300);
    })
    .catch(function () {
      alert('Something went wrong. Please try again or email sopo.fuifui@harcourts.co.nz directly.');
    });
  };
  window.resetForm = function () {
    var formContent = document.getElementById('formContent');
    var formSuccess = document.getElementById('formSuccess');
    formSuccess.classList.remove('show');
    formContent.style.display   = '';
    formContent.style.opacity   = '0';
    formContent.style.transform = 'translateY(12px)';
    formContent.querySelectorAll('input, textarea').forEach(function (el) { el.value = ''; });
    formContent.querySelectorAll('.cs-value').forEach(function (el) {
      var id = el.closest('.custom-select').dataset.select;
      var defaults = { intent:'Select an option', buyer:'Select type', budget:'Select range', contact:'Select preference' };
      el.textContent = defaults[id] || 'Select an option';
    });
    formContent.querySelectorAll('.cs-trigger').forEach(function (t) { t.classList.remove('selected','open'); });
    formContent.querySelectorAll('.cs-dropdown').forEach(function (d) { d.classList.remove('open'); });
    formContent.querySelectorAll('.cs-option').forEach(function  (o) { o.classList.remove('picked'); });
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        formContent.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
        formContent.style.opacity    = '1';
        formContent.style.transform  = 'translateY(0)';
      });
    });
  };
  window.addEventListener('scroll', function () {
    var y = window.scrollY;
    var s = document.querySelector('.hero-split');
    if (s && y < 800) { s.style.transform = 'translateY(' + (y * 0.12) + 'px)'; }
  });
})();
</script>