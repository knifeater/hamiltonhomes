      {p.landArea  && <div class="spec"><div class="spec-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></div><div><div class="spec-val">{p.landArea} m²</div><div class="spec-lbl">Land Area</div></div></div>}
      {p.tenure    && <div class="spec"><div class="spec-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><div><div class="spec-val">{p.tenure}</div><div class="spec-lbl">Tenure</div></div></div>}
