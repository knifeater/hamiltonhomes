---
// src/pages/homes/[slug].astro
import { properties } from "../../data/properties.js";

export function getStaticPaths() {
  return properties.map((p) => ({ params: { slug: p.slug }, props: { property: p } }));
}

const { property: p } = Astro.props;

// Other listings — exclude the current one, show up to 2
const otherListings = properties.filter((x) => x.slug !== p.slug).slice(0, 2);

const statusLabel = { "for-sale": "For Sale", "sold": "Sold", "under-offer": "Under Offer" }[p.status] ?? p.status;
const priceLabel  = p.status === "sold" ? "Sold for" : "Asking Price";
const hasGallery  = p.gallery   && p.gallery.length   > 0;
const hasTour     = !!p.tourUrl;
const hasDesc     = p.description && p.description.length > 0;
const hasFeatures = p.features  && p.features.length  > 0;
const hasSpecs    = p.floorArea || p.landArea || p.tenure;

// Card status helpers for other listings
function otherStatusLabel(s) {
  return { "for-sale": "For Sale", "sold": "Sold", "under-offer": "Under Offer" }[s] ?? s;
}
function otherStatusClass(s) {
  return { "for-sale": "ls-sale", "sold": "ls-sold", "under-offer": "ls-offer" }[s] ?? "ls-sold";
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{p.title}, {p.suburb} {p.postcode ?? ""} — {statusLabel} | Sopo Fuifui · Harcourts Hamilton Rototuna</title>
  <meta name="description" content={`${statusLabel} — ${p.title}, ${p.suburb}, ${p.city}. ${p.bedrooms} bed · ${p.bathrooms} bath · ${p.price}. Listed by Sopo Fuifui, Harcourts Hamilton Rototuna.`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { margin: 0; padding: 0; scroll-behavior: smooth; scroll-padding-top: 76px; overflow-x: hidden; -webkit-text-size-adjust: 100%; width: 100%; }
    body { margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; background: #fff; color: #1A2744; overflow-x: hidden; width: 100%; min-height: 100vh; }
    :root {
      --navy:#162040; --nmid:#1E2D56; --blue:#00AEEF; --bmid:#0090CC;
      --bpale:#E0F5FD; --white:#FFFFFF; --off:#F5F8FC; --text:#1A2744;
      --muted:#6B7590; --bdr:#E2E8F0; --bdr-b:rgba(0,174,239,.25);
    }

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:300;height:76px;display:flex;align-items:center;justify-content:space-between;padding:0 56px;background:var(--navy);border-bottom:2px solid var(--blue);}
    .nav-left{display:flex;align-items:center;gap:20px;text-decoration:none;}
    .hc-mark{display:flex;flex-direction:column;gap:3px;}
    .hc-word{font-size:20px;font-weight:700;color:#fff;letter-spacing:-.01em;line-height:1;}
    .hc-bar{width:26px;height:3px;background:var(--blue);border-radius:1px;}
    .nav-sep{width:1px;height:32px;background:rgba(255,255,255,.15);}
    .nav-agent-name{font-size:14px;font-weight:600;color:#fff;}
    .nav-agent-role{font-size:10px;font-weight:300;color:var(--blue);letter-spacing:.18em;text-transform:uppercase;}
    .nav-left:hover .hc-word,.nav-left:hover .nav-agent-name{color:rgba(255,255,255,.85);}
    .nav-left:hover .nav-agent-role{color:#33BFFF;}
    .nav-links{display:flex;align-items:center;gap:36px;list-style:none;}
    .nav-links a{font-size:12px;font-weight:400;color:rgba(255,255,255,.65);text-decoration:none;letter-spacing:.08em;text-transform:uppercase;transition:color .25s;}
    .nav-links a:hover{color:var(--blue);}
    .nav-cta{background:var(--blue)!important;color:var(--navy)!important;padding:10px 24px!important;border-radius:3px;font-weight:600!important;transition:background .25s!important;}
    .nav-cta:hover{background:#33BFFF!important;}
    .hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;width:44px;height:44px;cursor:pointer;background:none;border:none;padding:8px;border-radius:3px;flex-shrink:0;-webkit-tap-highlight-color:transparent;}
    .hamburger span{display:block;height:2px;background:#fff;border-radius:2px;transition:transform .38s cubic-bezier(.4,0,.2,1),opacity .25s,width .3s;transform-origin:center;}
    .hamburger span:nth-child(1){width:22px;}.hamburger span:nth-child(2){width:16px;}.hamburger span:nth-child(3){width:22px;}
    .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);width:22px;}
    .hamburger.open span:nth-child(2){opacity:0;width:0;}
    .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);width:22px;}
    .mobile-menu{position:fixed;top:76px;left:0;right:0;bottom:0;z-index:290;background:var(--navy);display:flex;flex-direction:column;transform:translateX(100%);transition:transform .4s cubic-bezier(.4,0,.2,1);overflow-y:auto;padding:40px 32px 60px;border-top:1px solid rgba(0,174,239,.2);}
    .mobile-menu.open{transform:translateX(0);}
    .mobile-menu ul{list-style:none;display:flex;flex-direction:column;gap:4px;margin-bottom:40px;}
    .mobile-menu ul li{opacity:0;transform:translateX(24px);transition:opacity .35s ease,transform .35s ease;}
    .mobile-menu.open ul li{opacity:1;transform:translateX(0);}
    .mobile-menu.open ul li:nth-child(1){transition-delay:.08s;}.mobile-menu.open ul li:nth-child(2){transition-delay:.13s;}.mobile-menu.open ul li:nth-child(3){transition-delay:.18s;}.mobile-menu.open ul li:nth-child(4){transition-delay:.23s;}
    .mobile-menu ul li a{display:block;font-size:26px;font-family:'Cormorant Garamond',serif;font-weight:300;color:rgba(255,255,255,.75);text-decoration:none;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.06);transition:color .2s;}
    .mobile-menu ul li a:hover{color:var(--blue);}
    .mobile-menu-cta{background:var(--blue);color:var(--navy);border:none;padding:16px 32px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;border-radius:3px;width:100%;opacity:0;transform:translateY(12px);transition:opacity .35s ease .3s,transform .35s ease .3s,background .25s;text-decoration:none;display:block;text-align:center;}
    .mobile-menu.open .mobile-menu-cta{opacity:1;transform:translateY(0);}
    .mobile-menu-cta:hover{background:#33BFFF;}
    .mobile-contact-row{display:flex;gap:12px;margin-top:16px;opacity:0;transform:translateY(12px);transition:opacity .35s ease .36s,transform .35s ease .36s;}
    .mobile-menu.open .mobile-contact-row{opacity:1;transform:translateY(0);}
    .mobile-contact-link{flex:1;display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.6);font-size:12px;font-weight:400;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;padding:13px 16px;border-radius:3px;transition:border-color .2s,color .2s;}
    .mobile-contact-link:hover{border-color:var(--blue);color:var(--blue);}

    /* ADDR STRIP (now above hero) */
    .addr-strip{margin-top:76px;}

    /* HERO */
    .listing-hero{width:100%;background:#0D1830;display:grid;grid-template-columns:1.65fr 1fr;grid-template-rows:310px 220px;gap:3px;}
    .gc{position:relative;overflow:hidden;cursor:pointer;background:#1E2D56;}
    .gc.main{grid-row:1/3;}
    .gc img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .55s ease;}
    .gc:hover img{transform:scale(1.04);}
    .gc-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;transition:transform .55s ease;}
    .gc:hover .gc-ph{transform:scale(1.04);}
    .ph1{background:linear-gradient(145deg,#1E3A6A 0%,#162040 60%,#0B1428 100%);}
    .ph2{background:linear-gradient(145deg,#1A3055 0%,#111D36 100%);}
    .ph3{background:linear-gradient(145deg,#162848 0%,#0E1A30 100%);}
    .gc-ph svg{opacity:.08;}
    .photo-chip{position:absolute;bottom:14px;right:14px;background:rgba(0,0,0,.6);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.15);border-radius:4px;padding:8px 14px;display:flex;align-items:center;gap:7px;font-size:12px;font-weight:500;color:rgba(255,255,255,.88);letter-spacing:.04em;cursor:pointer;transition:background .2s;white-space:nowrap;}
    .photo-chip:hover{background:rgba(0,0,0,.8);}
    .hero-status{position:absolute;top:16px;left:20px;z-index:10;padding:6px 16px;border-radius:3px;font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;}
    .hs-sold{background:rgba(22,32,64,.85);color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.2);backdrop-filter:blur(6px);}
    .hs-for-sale{background:var(--blue);color:var(--navy);}
    .hs-under-offer{background:#D97706;color:#fff;}

    /* LIGHTBOX */
    .lb{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .35s ease;}
    .lb.open{opacity:1;pointer-events:all;}
    .lb-bg{position:absolute;inset:0;background:rgba(10,16,30,.96);backdrop-filter:blur(6px);cursor:zoom-out;}
    .lb-frame{position:relative;z-index:1;display:flex;align-items:center;justify-content:center;width:100%;height:100%;padding:72px 88px;}
    .lb-img-wrap{position:relative;max-width:100%;max-height:100%;display:flex;align-items:center;justify-content:center;}
    .lb-img{max-width:100%;max-height:calc(100vh - 144px);object-fit:contain;border-radius:3px;opacity:0;transform:scale(.97);transition:opacity .32s ease,transform .32s ease;display:block;}
    .lb-img.visible{opacity:1;transform:scale(1);}
    .lb-arrow{position:fixed;top:50%;transform:translateY(-50%);z-index:2;width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s,border-color .2s,transform .2s;-webkit-tap-highlight-color:transparent;}
    .lb-arrow:hover{background:rgba(0,174,239,.25);border-color:rgba(0,174,239,.6);transform:translateY(-50%) scale(1.08);}
    .lb-arrow:active{transform:translateY(-50%) scale(.96);}
    .lb-arrow.prev{left:20px;}
    .lb-arrow.next{right:20px;}
    .lb-arrow.hidden{opacity:0;pointer-events:none;}
    .lb-close{position:fixed;top:18px;right:20px;z-index:2;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.7);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s,color .2s;}
    .lb-close:hover{background:rgba(255,255,255,.15);color:#fff;}
    .lb-counter{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:8px;z-index:2;}
    .lb-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.25);cursor:pointer;transition:background .2s,transform .2s;}
    .lb-dot.active{background:var(--blue);transform:scale(1.3);}
    .lb-num{position:fixed;bottom:22px;right:24px;font-size:11px;font-weight:500;color:rgba(255,255,255,.3);letter-spacing:.1em;z-index:2;}
    .lb-caption{position:fixed;bottom:48px;left:50%;transform:translateX(-50%);font-size:12px;color:rgba(255,255,255,.38);letter-spacing:.06em;z-index:2;white-space:nowrap;}

    /* ADDRESS */
    .addr-strip{width:100%;background:#fff;border-bottom:1px solid var(--bdr);border-top:none;}
    .addr-inner{max-width:1320px;margin:0 auto;padding:10px 48px;display:flex;align-items:center;justify-content:space-between;gap:24px;}
    .addr-bc{display:flex;align-items:center;gap:6px;flex-wrap:wrap;font-size:11px;color:var(--muted);letter-spacing:.04em;margin-bottom:5px;}
    .addr-bc a{color:var(--muted);text-decoration:none;transition:color .2s;}
    .addr-bc a:hover{color:var(--bmid);}
    .addr-bc span{color:var(--blue);opacity:.5;}
    .addr-title{font-family:'Cormorant Garamond',serif;font-size:clamp(24px,3.5vw,42px);font-weight:500;color:var(--navy);line-height:1;letter-spacing:-.01em;margin-bottom:6px;}
    .addr-suburb{font-size:14px;font-weight:400;color:var(--muted);display:flex;align-items:center;gap:5px;}
    .addr-suburb svg{color:var(--blue);flex-shrink:0;}
    .addr-price{text-align:right;flex-shrink:0;}
    .price-lbl{font-size:10px;font-weight:500;color:var(--muted);letter-spacing:.18em;text-transform:uppercase;margin-bottom:4px;}
    .price-val{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,3vw,40px);font-weight:500;color:var(--navy);line-height:1;}

    /* SPECS BAR */
    .specs-bar{width:100%;background:var(--off);border-bottom:1px solid var(--bdr);position:relative;}
    .specs-bar-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;-ms-overflow-style:none;}
    .specs-bar-scroll::-webkit-scrollbar{display:none;}
    .specs-inner{max-width:1320px;margin:0 auto;padding:0 48px;display:flex;align-items:center;min-width:max-content;}
    .spec{display:flex;align-items:center;gap:10px;padding:15px 26px 15px 0;margin-right:26px;border-right:1px solid var(--bdr);white-space:nowrap;}
    .spec:last-child{border-right:none;margin-right:0;}
    .spec-icon{color:var(--blue);flex-shrink:0;}
    .spec-val{font-size:16px;font-weight:600;color:var(--navy);line-height:1;}
    .spec-lbl{font-size:10px;font-weight:400;color:var(--muted);letter-spacing:.1em;margin-top:2px;}
    /* Fade edge — mobile only, hidden via JS once scrolled */
    .specs-fade{display:none;position:absolute;top:0;right:0;bottom:0;width:72px;pointer-events:none;background:linear-gradient(to right,transparent,var(--off) 80%);transition:opacity .3s;z-index:2;}
    .specs-swipe-hint{display:none;position:absolute;right:10px;top:50%;transform:translateY(-50%);z-index:3;align-items:center;gap:4px;background:var(--navy);color:rgba(255,255,255,.75);font-size:9px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;padding:5px 9px 5px 8px;border-radius:20px;border:1px solid rgba(0,174,239,.25);pointer-events:none;transition:opacity .4s;}
    .specs-swipe-hint svg{color:var(--blue);}
    @media(max-width:680px){
      .specs-fade{display:block;}
      .specs-swipe-hint{display:flex;}
      .specs-inner{padding:0 16px;}
      .spec{padding:12px 18px 12px 0;margin-right:18px;}
      .spec-val{font-size:14px;}
    }

    /* BODY */
    .page-body{width:100%;background:var(--off);padding:32px 0 0;}
    .body-inner{max-width:1320px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr 372px;gap:28px;align-items:start;}
    .content-col{display:flex;flex-direction:column;gap:14px;padding-bottom:32px;}
    .card{background:#fff;border:1px solid var(--bdr);border-radius:5px;overflow:hidden;}
    .card-head{padding:18px 26px 0;display:flex;align-items:center;justify-content:space-between;gap:12px;}
    .card-title{font-size:12px;font-weight:700;color:var(--navy);letter-spacing:.12em;text-transform:uppercase;display:flex;align-items:center;gap:10px;}
    .card-title::before{content:'';display:block;width:3px;height:15px;background:var(--blue);border-radius:2px;flex-shrink:0;}
    .card-body{padding:16px 26px 26px;}
    .desc p{font-size:15px;font-weight:400;color:#374265;line-height:1.9;}
    .desc p+p{margin-top:14px;}
    .feat-grid{display:grid;grid-template-columns:1fr 1fr;}
    .fi{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--bdr);font-size:13.5px;font-weight:400;color:#374265;}
    .fi:nth-child(odd){padding-right:20px;border-right:1px solid var(--bdr);}
    .fi:nth-child(even){padding-left:20px;}
    .fi:nth-last-child(-n+2){border-bottom:none;}
    .fi-dot{width:7px;height:7px;border-radius:50%;background:var(--blue);flex-shrink:0;}
    .dtable{width:100%;border-collapse:collapse;}
    .dtable tr{border-bottom:1px solid var(--bdr);}
    .dtable tr:last-child{border-bottom:none;}
    .dtable td{padding:11px 0;font-size:13.5px;}
    .dtable td:first-child{font-weight:600;color:var(--navy);width:40%;padding-right:12px;}
    .dtable td:last-child{font-weight:400;color:#374265;}
    .gstrip{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;margin:0 26px 26px;border-radius:4px;overflow:hidden;}
    .gs{height:112px;position:relative;overflow:hidden;cursor:pointer;}
    .gs .gc-ph{height:100%;transition:transform .5s;}
    .gs:hover .gc-ph{transform:scale(1.05);}
    .gs-more{position:absolute;inset:0;background:rgba(22,32,64,.62);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:3px;}
    .gs-more-n{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:#fff;}
    .gs-more-l{font-size:9px;color:rgba(255,255,255,.5);letter-spacing:.12em;text-transform:uppercase;}
    .tour-wrap{margin:0 26px 26px;border-radius:4px;overflow:hidden;aspect-ratio:16/7;position:relative;background:#0D1830;}
    .tour-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:none;}
    .tour-ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;background-image:repeating-linear-gradient(0deg,rgba(0,174,239,.04) 0,rgba(0,174,239,.04) 1px,transparent 1px,transparent 48px),repeating-linear-gradient(90deg,rgba(0,174,239,.04) 0,rgba(0,174,239,.04) 1px,transparent 1px,transparent 48px);}
    .tour-sphere{width:96px;height:96px;border-radius:50%;background:radial-gradient(ellipse at 38% 35%,#2A4080,#162040 60%,#0A1220);border:1px solid rgba(0,174,239,.22);box-shadow:0 0 48px rgba(0,174,239,.12);display:flex;align-items:center;justify-content:center;}
    .tour-lbl{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:300;color:rgba(255,255,255,.5);}
    .tour-play{position:absolute;width:50px;height:50px;border-radius:50%;background:var(--blue);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;animation:tpulse 2.5s infinite;transition:transform .25s;}
    .tour-play:hover{transform:scale(1.1);}
    @keyframes tpulse{0%{box-shadow:0 0 0 0 rgba(0,174,239,.5);}70%{box-shadow:0 0 0 18px rgba(0,174,239,0);}100%{box-shadow:0 0 0 0 rgba(0,174,239,0);}}
    .tour-note{font-size:11px;color:rgba(255,255,255,.25);letter-spacing:.1em;}
    .tour-badge{display:flex;align-items:center;gap:6px;font-size:10px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;border-radius:20px;padding:4px 12px;}
    .tb-live{color:var(--blue);background:rgba(0,174,239,.08);border:1px solid var(--bdr-b);}
    .tb-soon{color:var(--muted);background:none;border:1px solid var(--bdr);}
    .tb-dot{width:5px;height:5px;border-radius:50%;background:currentColor;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

    /* SIDEBAR */
    .sidebar-col{position:sticky;top:92px;display:flex;flex-direction:column;gap:14px;padding-bottom:32px;}
    .enq-card{background:#fff;border:1px solid var(--bdr);border-radius:5px;overflow:hidden;box-shadow:0 4px 24px rgba(22,32,64,.08);}
    .enq-top{background:var(--navy);padding:22px 22px 18px;border-bottom:3px solid var(--blue);}
    .enq-plbl{font-size:10px;font-weight:400;color:rgba(255,255,255,.38);letter-spacing:.18em;text-transform:uppercase;margin-bottom:3px;}
    .enq-pval{font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:500;color:#fff;line-height:1;margin-bottom:7px;}
    .enq-addr{font-size:12.5px;font-weight:300;color:rgba(255,255,255,.42);line-height:1.5;margin-bottom:11px;}
    .enq-pill{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;border-radius:3px;font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;}
    .ep-sold{background:rgba(255,255,255,.08);color:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.15);}
    .ep-for-sale{background:rgba(0,174,239,.15);color:var(--blue);border:1px solid rgba(0,174,239,.3);}
    .ep-under-offer{background:rgba(217,119,6,.15);color:#D97706;border:1px solid rgba(217,119,6,.3);}
    .ep-dot{width:5px;height:5px;border-radius:50%;background:currentColor;}
    .enq-form{padding:18px 22px 22px;display:flex;flex-direction:column;gap:11px;}
    .f2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
    .fg{display:flex;flex-direction:column;gap:5px;}
    .fl{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.16em;text-transform:uppercase;}
    .fi-inp,.fi-ta{background:var(--off);border:1px solid var(--bdr);border-radius:3px;padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:13.5px;color:var(--navy);outline:none;transition:border-color .2s,background .2s;width:100%;}
    .fi-inp::placeholder,.fi-ta::placeholder{color:#B8C2D8;}
    .fi-inp:focus,.fi-ta:focus{border-color:var(--blue);background:#fff;}
    .fi-ta{resize:vertical;min-height:84px;}
    .enq-submit{width:100%;background:var(--blue);color:var(--navy);border:none;padding:15px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;border-radius:3px;transition:background .25s,box-shadow .25s;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:3px;}
    .enq-submit:hover{background:#33BFFF;box-shadow:0 6px 24px rgba(0,174,239,.28);}
    .enq-submit svg{transition:transform .25s;}
    .enq-submit:hover svg{transform:translateX(3px);}
    .enq-or{display:flex;align-items:center;gap:10px;margin:2px 0;font-size:10px;font-weight:500;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;}
    .enq-or::before,.enq-or::after{content:'';flex:1;height:1px;background:var(--bdr);}
    .enq-call{width:100%;background:transparent;color:var(--navy);border:1.5px solid var(--bdr);border-radius:3px;padding:12px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;transition:border-color .2s,color .2s;}
    .enq-call:hover{border-color:var(--blue);color:var(--bmid);}
    .enq-priv{font-size:10.5px;color:#B8C2D8;text-align:center;line-height:1.6;margin-top:2px;}
    .enq-suc{display:none;flex-direction:column;align-items:center;text-align:center;padding:36px 20px;gap:12px;}
    .enq-suc.show{display:flex;animation:fadeIn .4s ease;}
    @keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
    .suc-ring{width:60px;height:60px;border-radius:50%;background:rgba(0,174,239,.1);border:2px solid var(--blue);display:flex;align-items:center;justify-content:center;}
    .suc-chk{stroke-dasharray:28;stroke-dashoffset:28;animation:drawchk .45s .2s ease forwards;}
    @keyframes drawchk{to{stroke-dashoffset:0;}}
    .suc-ttl{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--navy);}
    .suc-msg{font-size:13px;color:var(--muted);line-height:1.7;max-width:240px;}
    .suc-reset{background:none;border:1px solid var(--bdr);border-radius:3px;padding:10px 20px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;color:var(--blue);cursor:pointer;letter-spacing:.1em;text-transform:uppercase;transition:border-color .2s,background .2s;}
    .suc-reset:hover{border-color:var(--blue);background:var(--bpale);}
    .agent-card{background:#fff;border:1px solid var(--bdr);border-radius:5px;overflow:hidden;}
    .agt{background:var(--navy);padding:18px 20px;display:flex;align-items:center;gap:14px;border-bottom:2px solid var(--blue);}
    .ava{width:50px;height:50px;border-radius:50%;background:linear-gradient(160deg,#253570,#162040);border:2px solid rgba(0,174,239,.4);flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;}
    .ava img{width:100%;height:100%;object-fit:cover;object-position:center 20%;}
    .ava svg{opacity:.22;}
    .agt-nm{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:500;color:#fff;line-height:1.15;}
    .agt-rl{font-size:10px;font-weight:300;color:rgba(255,255,255,.42);letter-spacing:.07em;margin-top:3px;}
    .agt-contacts{padding:14px 20px;display:flex;flex-direction:column;gap:10px;border-bottom:1px solid var(--bdr);}
    .ac-lbl{font-size:9px;font-weight:700;color:var(--muted);letter-spacing:.2em;text-transform:uppercase;margin-bottom:1px;}
    .ac-val{font-size:13px;color:var(--text);}
    .ac-val a{color:var(--text);text-decoration:none;transition:color .2s;}
    .ac-val a:hover{color:var(--bmid);}
    .agt-stats{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--bdr);}
    .ast{background:#fff;padding:13px 16px;text-align:center;}
    .ast-n{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:500;color:var(--navy);line-height:1;}
    .ast-n span{color:var(--blue);}
    .ast-l{font-size:9px;color:var(--muted);letter-spacing:.08em;margin-top:3px;}
    .back-card{background:#fff;border:1px solid var(--bdr);border-radius:5px;padding:14px 20px;}
    .back-a{display:flex;align-items:center;gap:9px;font-size:12.5px;font-weight:500;color:var(--navy);text-decoration:none;letter-spacing:.04em;transition:color .2s;}
    .back-a:hover{color:var(--bmid);}
    .back-a svg{transition:transform .2s;flex-shrink:0;}
    .back-a:hover svg{transform:translateX(-3px);}

    /* OTHER LISTINGS */
    .other-wrap{width:100%;background:#fff;border-top:1px solid var(--bdr);padding:60px 0 72px;}
    .other-inner{max-width:1320px;margin:0 auto;padding:0 48px;}
    .other-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:32px;gap:16px;flex-wrap:wrap;}
    .other-eyebrow{font-size:11px;font-weight:600;color:var(--blue);letter-spacing:.25em;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:10px;}
    .other-eyebrow::before{content:'';display:block;width:22px;height:2px;background:var(--blue);border-radius:1px;}
    .other-title{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,3vw,38px);font-weight:400;color:var(--navy);line-height:1;}
    .other-title em{font-style:italic;color:var(--bmid);}
    .other-viewall{font-size:12px;font-weight:600;color:var(--navy);text-decoration:none;letter-spacing:.1em;text-transform:uppercase;display:flex;align-items:center;gap:6px;padding-bottom:2px;border-bottom:2px solid var(--blue);transition:color .2s;white-space:nowrap;flex-shrink:0;}
    .other-viewall:hover{color:var(--blue);}
    .listings-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
    .lcard{background:#fff;border:1px solid var(--bdr);border-radius:6px;overflow:hidden;cursor:pointer;transition:box-shadow .3s,transform .3s;text-decoration:none;display:block;}
    .lcard:hover{box-shadow:0 12px 40px rgba(22,32,64,.12);transform:translateY(-4px);}
    .lcard-img{position:relative;height:200px;overflow:hidden;}
    .lcard-img .gc-ph{height:100%;}
    .lcard:hover .lcard-img .gc-ph{transform:scale(1.04);}
    .lcard-status{position:absolute;top:12px;left:14px;z-index:2;padding:4px 12px;border-radius:3px;font-size:9px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;}
    .ls-sold{background:rgba(22,32,64,.82);color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.2);backdrop-filter:blur(4px);}
    .ls-sale{background:var(--blue);color:var(--navy);}
    .ls-offer{background:#D97706;color:#fff;}
    .lcard-body{padding:18px 20px 20px;}
    .lcard-addr{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:var(--navy);line-height:1.15;margin-bottom:3px;}
    .lcard-suburb{font-size:12px;color:var(--muted);margin-bottom:14px;}
    .lcard-specs{display:flex;align-items:center;gap:14px;padding-bottom:12px;border-bottom:1px solid var(--bdr);}
    .lcard-spec{display:flex;align-items:center;gap:5px;font-size:12.5px;color:var(--muted);}
    .lcard-spec svg{color:var(--blue);flex-shrink:0;}
    .lcard-foot{display:flex;align-items:center;justify-content:space-between;padding-top:12px;}
    .lcard-price{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;color:var(--navy);}
    .lcard-cta{font-size:11px;font-weight:600;color:var(--bmid);letter-spacing:.1em;text-transform:uppercase;display:flex;align-items:center;gap:5px;transition:color .2s;}
    .lcard:hover .lcard-cta{color:var(--blue);}
    .lcard-cta svg{transition:transform .2s;}
    .lcard:hover .lcard-cta svg{transform:translateX(3px);}
    /* CTA card (dark) */
    .lcard-cta-card{background:var(--navy);border-color:var(--navy);cursor:pointer;}
    .lcard-cta-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(22,32,64,.25);}

    /* FOOTER */
    footer{background:var(--navy);border-top:3px solid var(--blue);padding:64px 80px 0;width:100%;display:block;}
    .footer-inner{max-width:1400px;margin:0 auto;}
    .ftop{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:56px;padding-bottom:48px;border-bottom:1px solid rgba(255,255,255,.07);}
    .fln{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:300;color:var(--white);margin-bottom:2px;}
    .fln em{font-style:italic;color:var(--blue);}
    .fls{font-size:10px;font-weight:300;color:var(--blue);letter-spacing:.22em;text-transform:uppercase;margin-bottom:16px;}
    .fbio{font-size:13px;font-weight:400;color:rgba(255,255,255,.32);line-height:1.75;max-width:270px;}
    .fch{font-size:10px;font-weight:600;color:rgba(255,255,255,.45);letter-spacing:.22em;text-transform:uppercase;margin-bottom:18px;}
    .flinks{list-style:none;display:flex;flex-direction:column;gap:11px;}
    .flinks a{font-size:13px;font-weight:300;color:rgba(255,255,255,.35);text-decoration:none;transition:color .2s;}
    .flinks a:hover{color:var(--blue);}
    .fcontact{display:flex;flex-direction:column;gap:15px;}
    .fci-lbl{font-size:9px;font-weight:500;color:rgba(255,255,255,.2);letter-spacing:.22em;text-transform:uppercase;margin-bottom:2px;}
    .fci-val{font-size:13px;font-weight:300;color:rgba(255,255,255,.46);}
    .fci-val a{color:rgba(255,255,255,.46);text-decoration:none;transition:color .2s;}
    .fci-val a:hover{color:var(--blue);}
    .fbot-wrap{border-top:1px solid rgba(255,255,255,.07);}
    .fbot-main{display:flex;align-items:center;justify-content:space-between;padding:24px 0 28px;gap:16px;flex-wrap:wrap;}
    .fcopy{font-size:11px;font-weight:300;color:rgba(255,255,255,.22);letter-spacing:.04em;}
    .fmp{font-size:11px;font-weight:300;color:rgba(255,255,255,.22);letter-spacing:.04em;}
    .fmp a{color:var(--blue);text-decoration:none;font-weight:400;opacity:.75;transition:all .2s;}
    .fmp a:hover{color:#33BFFF;opacity:1;}
    .fhc{display:flex;align-items:center;gap:10px;}
    .fhc-txt{font-size:10px;font-weight:300;color:rgba(255,255,255,.18);letter-spacing:.1em;text-transform:uppercase;}
    .fhc-logo{font-size:13px;font-weight:700;color:rgba(255,255,255,.44);line-height:1;}
    .fhc-ln{width:16px;height:2px;background:var(--blue);border-radius:1px;opacity:.55;margin-top:3px;}

    /* RESPONSIVE */
    @media(max-width:1060px){
      nav{padding:0 28px;}
      .nav-links{display:none;}
      .hamburger{display:flex;}
      .listing-hero{grid-template-rows:260px 180px;}
      .addr-inner,.specs-inner,.body-inner,.other-inner{padding-left:28px;padding-right:28px;}
      footer{padding:60px 28px 0;}
      .body-inner{grid-template-columns:1fr;gap:0;}
      .content-col{padding-bottom:0;}
      .sidebar-col{position:static;padding-bottom:28px;}
      .listings-grid{grid-template-columns:repeat(2,1fr);}
      .ftop{grid-template-columns:1fr 1fr;gap:36px;}
      .fbot-main{flex-direction:column;align-items:flex-start;gap:10px;padding:20px 0 24px;}
    }
    @media(max-width:680px){
      nav{padding:0 16px;}

      /* Address strip — compact on mobile */
      .addr-strip{margin-top:76px;}
      .addr-inner{padding:8px 16px;flex-direction:column;gap:6px;align-items:flex-start;}
      .addr-bc{font-size:10px;margin-bottom:3px;gap:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;flex-wrap:nowrap;}
      .addr-title{font-size:clamp(18px,5vw,26px);margin-bottom:4px;}
      .addr-suburb{font-size:12px;}
      .addr-price{text-align:left;}
      .price-lbl{font-size:9px;}
      .price-val{font-size:clamp(20px,5vw,28px);}

      /* Hero */
      .listing-hero{grid-template-columns:1fr;grid-template-rows:240px;}
      .gc:not(.main){display:none;}
      .gc.main{grid-row:auto;}

      /* Body */
      .body-inner{padding:0;}
      .page-body{padding:16px 0 0;}
      .content-col{padding:0 16px;gap:12px;}
      .sidebar-col{padding:0 16px 24px;}

      /* Cards */
      .card-head{padding:14px 16px 0;}
      .card-body{padding:12px 16px 20px;}

      /* Key features — single column, no orphan padding */
      .feat-grid{grid-template-columns:1fr;}
      .fi{padding:10px 0;border-right:none !important;padding-right:0 !important;padding-left:0 !important;}
      .fi:nth-child(odd){padding-right:0;border-right:none;}
      .fi:nth-child(even){padding-left:0;}
      .fi:nth-last-child(-n+2){border-bottom:1px solid var(--bdr);}
      .fi:last-child{border-bottom:none;}

      /* Property details table */
      .dtable td{font-size:12.5px;padding:9px 0;}
      .dtable td:first-child{width:45%;}

      /* Gallery strip */
      .gstrip{margin:0 0 20px;grid-template-columns:1fr 1fr;}
      .tour-wrap{margin:0 0 20px;}

      /* Enquiry form */
      .enq-top{padding:16px 16px 14px;}
      .enq-pval{font-size:28px;}
      .enq-form{padding:14px 16px 18px;}
      .f2{grid-template-columns:1fr;}
      .enq-card{border-radius:4px;}

      /* Other listings */
      .other-inner{padding-left:16px;padding-right:16px;}
      .other-wrap{padding:40px 0 52px;}
      .listings-grid{grid-template-columns:1fr;}

      /* Footer */
      footer{padding:40px 16px 0;}
      .ftop{grid-template-columns:1fr;gap:28px;}
      .fbot-main{flex-direction:column;align-items:flex-start;gap:8px;padding:16px 0 20px;}
    }
    @media(max-width:400px){
      .listing-hero{grid-template-rows:200px;}
      .addr-title{font-size:18px;}
      .price-val{font-size:20px;}
      .enq-pval{font-size:24px;}
      .spec-val{font-size:13px;}
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <!-- CHANGE 1: .nav-left is now an <a> tag linking to the homepage -->
  <a href="https://hamiltonhomes.netlify.app/" class="nav-left">
    <div class="hc-mark"><div class="hc-word">Harcourts</div><div class="hc-bar"></div></div>
    <div class="nav-sep"></div>
    <div><div class="nav-agent-name">Sopo Fuifui</div><div class="nav-agent-role">Licensed Sales Consultant</div></div>
  </a>
  <ul class="nav-links">
    <!-- CHANGE 2: Listings links to the full listings URL -->
    <li><a href="https://hamiltonhomes.netlify.app/listings/">Listings</a></li>
    <li><a href="/#tours">360° Tours</a></li>
    <li><a href="/#about">About</a></li>
    <li><a href="/#contact">Contact</a></li>
    <li><a href="/#contact" class="nav-cta">Enquire</a></li>
  </ul>
  <button class="hamburger" id="hamburger" aria-label="Open menu"><span></span><span></span><span></span></button>
</nav>
<div class="mobile-menu" id="mobileMenu">
  <ul>
    <li><a href="https://hamiltonhomes.netlify.app/listings/" class="ml">Listings</a></li>
    <li><a href="/#tours"    class="ml">360° Tours</a></li>
    <li><a href="/#about"    class="ml">About</a></li>
    <li><a href="/#contact"  class="ml">Contact</a></li>
  </ul>
  <a href="/#contact" class="mobile-menu-cta ml" style="text-align:center;display:block;">Enquire Now</a>
  <div class="mobile-contact-row">
    <a href="tel:02102667154" class="mobile-contact-link ml">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.22 1.18 2 2 0 012.22 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>Call
    </a>
    <a href="mailto:sopo.fuifui@harcourts.co.nz" class="mobile-contact-link ml">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>Email
    </a>
  </div>
</div>

<!-- ADDRESS (above hero images) -->
<div class="addr-strip">
  <div class="addr-inner">
    <div>
      <div class="addr-bc">
        <a href="/">Home</a><span>›</span><a href="https://hamiltonhomes.netlify.app/listings/">Listings</a><span>›</span>
        <a href="https://hamiltonhomes.netlify.app/listings/">{p.suburb}</a><span>›</span>{p.title}
      </div>
      <h1 class="addr-title">{p.title}</h1>
      <div class="addr-suburb">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        {p.suburb}, {p.city} {p.postcode ?? ""}
      </div>
    </div>
    <div class="addr-price">
      <div class="price-lbl">{priceLabel}</div>
      <div class="price-val">{p.price}</div>
    </div>
  </div>
</div>

<!-- HERO -->
<div class="listing-hero">
  <div class="gc main" onclick={hasGallery ? "lbOpen(0)" : undefined}>
    {hasGallery ? (
      <img src={p.gallery[0].src} alt={p.gallery[0].alt} />
    ) : (
      <div class="gc-ph ph1">
        <svg width="200" height="130" viewBox="0 0 480 320" fill="none">
          <rect x="60" y="160" width="360" height="160" fill="white"/>
          <polygon points="28,160 240,44 452,160" fill="white"/>
          <rect x="310" y="218" width="100" height="102" fill="rgba(0,0,0,.18)"/>
          <rect x="168" y="232" width="88" height="88" fill="rgba(0,0,0,.22)"/>
          <rect x="78" y="200" width="78" height="58" fill="rgba(0,0,0,.14)"/>
          <rect x="236" y="196" width="66" height="52" fill="rgba(0,0,0,.14)"/>
          <rect x="390" y="166" width="30" height="58" fill="white"/>
        </svg>
      </div>
    )}
    <div class={`hero-status hs-${p.status}`}>{statusLabel}</div>
    {hasGallery && <div class="photo-chip" onclick="lbOpen(0);event.stopPropagation()"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>View all {p.gallery.length} photos</div>}
  </div>
  <div class="gc" onclick={hasGallery && p.gallery[1] ? "lbOpen(1)" : undefined}>{hasGallery && p.gallery[1] ? <img src={p.gallery[1].src} alt={p.gallery[1].alt}/> : <div class="gc-ph ph2"></div>}</div>
  <div class="gc" onclick={hasGallery && p.gallery[2] ? "lbOpen(2)" : undefined}>{hasGallery && p.gallery[2] ? <img src={p.gallery[2].src} alt={p.gallery[2].alt}/> : <div class="gc-ph ph3"></div>}</div>
</div>

<!-- LIGHTBOX -->
<script is:inline define:vars={{ gallery: p.gallery ?? [] }}>
  window.__gallery = gallery;
</script>
<div class="lb" id="lb" role="dialog" aria-modal="true" aria-label="Photo gallery">
  <div class="lb-bg" onclick="lbClose()"></div>
  <div class="lb-frame">
    <div class="lb-img-wrap">
      <img class="lb-img" id="lbImg" src="" alt="" />
    </div>
  </div>
  <button class="lb-arrow prev" id="lbPrev" aria-label="Previous photo" onclick="lbStep(-1)">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="lb-arrow next" id="lbNext" aria-label="Next photo" onclick="lbStep(1)">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <button class="lb-close" onclick="lbClose()" aria-label="Close gallery">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <div class="lb-counter" id="lbDots"></div>
  <div class="lb-num" id="lbNum"></div>
</div>

<!-- SPECS BAR -->
<div class="specs-bar" id="specsBar">
  <div class="specs-fade" id="specsFade"></div>
  <div class="specs-swipe-hint" id="specsHint">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    Swipe
  </div>
  <div class="specs-bar-scroll" id="specsScroll">
    <div class="specs-inner">
