<script is:inline>
(function(){
  /* ── NAV ── */
  var h=document.getElementById('hamburger'),m=document.getElementById('mobileMenu');
  h.addEventListener('click',function(){h.classList.toggle('open');m.classList.toggle('open');document.body.style.overflow=m.classList.contains('open')?'hidden':'';});
  document.querySelectorAll('.ml').forEach(function(l){l.addEventListener('click',function(){h.classList.remove('open');m.classList.remove('open');document.body.style.overflow='';});});

  /* ── SPECS SWIPE HINT ── */
  (function(){
    var scroll=document.getElementById('specsScroll');
    var fade=document.getElementById('specsFade');
    var hint=document.getElementById('specsHint');
    if(!scroll||!fade||!hint){return;}
    function update(){
      var atEnd=scroll.scrollLeft+scroll.clientWidth>=scroll.scrollWidth-4;
      var moved=scroll.scrollLeft>10;
      fade.style.opacity=atEnd?'0':'1';
      hint.style.opacity=(atEnd||moved)?'0':'1';
    }
    scroll.addEventListener('scroll',update,{passive:true});
    // Check on load in case content fits without scrolling
    setTimeout(function(){
      var canScroll=scroll.scrollWidth>scroll.clientWidth+4;
      if(!canScroll){fade.style.opacity='0';hint.style.opacity='0';}
    },100);
  })();;

  /* ── LIGHTBOX ── */
  var lb=document.getElementById('lb');
  var lbImg=document.getElementById('lbImg');
  var lbPrev=document.getElementById('lbPrev');
  var lbNext=document.getElementById('lbNext');
  var lbDots=document.getElementById('lbDots');
  var lbNum=document.getElementById('lbNum');
  var gallery=window.__gallery||[];
  var current=0;

  function buildDots(){
    lbDots.innerHTML='';
    if(gallery.length<=1){return;}
    gallery.forEach(function(_,i){
      var d=document.createElement('button');
      d.className='lb-dot'+(i===current?' active':'');
      d.setAttribute('aria-label','Photo '+(i+1));
      d.onclick=function(){lbGoto(i);};
      lbDots.appendChild(d);
    });
  }

  function updateUI(){
    lbNum.textContent=(current+1)+' / '+gallery.length;
    lbPrev.classList.toggle('hidden', current===0);
    lbNext.classList.toggle('hidden', current===gallery.length-1);
    var dots=lbDots.querySelectorAll('.lb-dot');
    dots.forEach(function(d,i){d.classList.toggle('active',i===current);});
  }

  function lbGoto(idx){
    var img=lbImg;
    img.classList.remove('visible');
    setTimeout(function(){
      img.src=gallery[idx].src;
      img.alt=gallery[idx].alt||('Photo '+(idx+1));
      img.onload=function(){img.classList.add('visible');};
      // If cached, onload may not fire
      if(img.complete){img.classList.add('visible');}
      current=idx;
      updateUI();
    },180);
  }

  window.lbOpen=function(idx){
    if(!gallery.length){return;}
    current=idx||0;
    buildDots();
    lb.classList.add('open');
    document.body.style.overflow='hidden';
    // Load image without transition delay on first open
    lbImg.classList.remove('visible');
    lbImg.src=gallery[current].src;
    lbImg.alt=gallery[current].alt||('Photo '+(current+1));
    lbImg.onload=function(){lbImg.classList.add('visible');};
    if(lbImg.complete){lbImg.classList.add('visible');}
    updateUI();
  };

  window.lbClose=function(){
    lb.classList.remove('open');
    document.body.style.overflow='';
    setTimeout(function(){lbImg.classList.remove('visible');lbImg.src='';},350);
  };

  window.lbStep=function(dir){
    var next=current+dir;
    if(next<0||next>=gallery.length){return;}
    lbGoto(next);
  };

  /* Keyboard navigation */
  document.addEventListener('keydown',function(e){
    if(!lb.classList.contains('open')){return;}
    if(e.key==='ArrowLeft'){lbStep(-1);}
    else if(e.key==='ArrowRight'){lbStep(1);}
    else if(e.key==='Escape'){lbClose();}
  });

  /* Touch swipe */
  var touchStartX=0;
  lb.addEventListener('touchstart',function(e){touchStartX=e.touches[0].clientX;},{passive:true});
  lb.addEventListener('touchend',function(e){
    var dx=e.changedTouches[0].clientX-touchStartX;
    if(Math.abs(dx)>50){lbStep(dx<0?1:-1);}
  });

  /* ── ENQUIRY FORM ── */
  window.submitEnq=function(e){
    e.preventDefault();
    var form=e.target;
    var btn=document.getElementById('enqSubmitBtn');
    btn.disabled=true;
    btn.textContent='Sending…';

    var data=new FormData(form);
    fetch('/',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body:new URLSearchParams(data).toString()
    })
    .then(function(res){
      if(res.ok){
        var f=document.getElementById('enqForm'),s=document.getElementById('enqSuc');
        f.style.transition='opacity .25s,transform .25s';f.style.opacity='0';f.style.transform='translateY(-8px)';
        setTimeout(function(){f.style.display='none';s.classList.add('show');},260);
      } else {
        btn.disabled=false;btn.innerHTML='Send Enquiry <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
        alert('Something went wrong. Please try again or call Sopo directly.');
      }
    })
    .catch(function(){
      btn.disabled=false;btn.innerHTML='Send Enquiry <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
      alert('Something went wrong. Please try again or call Sopo directly.');
    });
  };

  window.resetEnq=function(){
    var f=document.getElementById('enqForm'),s=document.getElementById('enqSuc');
    var btn=document.getElementById('enqSubmitBtn');
    s.classList.remove('show');f.style.display='';f.style.opacity='0';f.style.transform='translateY(8px)';
    f.querySelectorAll('input,textarea').forEach(function(el){if(el.type!=='hidden'){el.value='';}});
    btn.disabled=false;btn.innerHTML='Send Enquiry <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
    requestAnimationFrame(function(){requestAnimationFrame(function(){f.style.transition='opacity .3s,transform .3s';f.style.opacity='1';f.style.transform='translateY(0)';});});
  };
})();
</script>
</body>
</html>